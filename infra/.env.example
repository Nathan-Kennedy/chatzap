# Opcional: copie para infra/.env (não é obrigatório).
# Chave global da Evolution (header "apikey" nas chamadas REST e no JSON do webhook).
EVOLUTION_AUTH_API_KEY=wa_saas_evolution_dev_key_change_me

# Porta no host para aceder à Evolution (evita conflito com a API Go na 8080).
EVOLUTION_HTTP_PORT=8081

# Evolution Go
# EVOLUTION_CLIENT_NAME=wa_saas
# EVOLUTION_AUTH_DB_NAME=evogo_auth
# EVOLUTION_USERS_DB_NAME=evogo_users
# EVOLUTION_DATABASE_SAVE_MESSAGES=false
# EVOLUTION_WADEBUG=INFO
# EVOLUTION_LOGTYPE=console

# WhatsApp Gateway (Baileys) — perfil Docker: docker compose --profile gateway up -d
# WA_GATEWAY_HTTP_PORT=3090
# WA_INSTANCE_NAME=default

# API Go no compose (perfil api): evolution | baileys | none
# WHATSAPP_PROVIDER=evolution
#
# Webhook (mensagens recebidas): o compose (perfil api) define por defeito PUBLIC_WEBHOOK_BASE_URL=http://api:8080
# para a Evolution no mesmo stack alcançar a API pela rede Docker.
# Não definas aqui host.docker.internal nesse caso.
#
# Se a API corre no host (`go run`) e só Postgres/Redis/Evolution estão no Docker:
# no backend/.env usa PUBLIC_WEBHOOK_BASE_URL=http://host.docker.internal:<porta da API>
# e reinicia a Evolution após alterações: docker compose ... up -d evolution
#
# PUBLIC_WEBHOOK_BASE_URL=http://api:8080
