# Copie para backend/.env — guia: ../docs/GUIA_CONFIGURACAO_API.md
# Dev local: ../docs/DEV_LOCAL.md
#
# === Perfil rápido (recomendado para primeiro run) ===
# Sobe só com: docker compose -f infra/docker-compose.deps.yml up -d
# Depois: npm run dev:stack na raiz do repo (API + Vite).
# Sem Evolution nem chaves de LLM.

ENV=development
# Alinha com apps/web/.env (VITE_* na mesma porta). Evita 8080 no browser e 8088 na API.
HTTP_PORT=8088
LOG_LEVEL=info

# Alinhar com Docker (infra/docker-compose.deps.yml): mesmo user/pass/db e portas expostas.
DATABASE_URL=postgres://wa_saas:wa_saas_dev_change_me@127.0.0.1:5432/wa_saas?sslmode=disable
REDIS_URL=redis://127.0.0.1:6379/0
# CSV: inclui Vite local e, se a API está na Hetzner e o front no PC, mantém localhost aqui.
# Ver docs/DEV_LOCAL.md secção 8 (API remota + frontend local).
CORS_ALLOW_ORIGINS=http://localhost:5173

# evolution | baileys | none — use none para testar API + web sem WhatsApp REST
WHATSAPP_PROVIDER=none

# Webhooks: em dev podes usar só isto (nunca em produção)
INSECURE_SKIP_WEBHOOK_AUTH=true

INTERNAL_API_KEY=troque_por_chave_longa_secreta

# Encriptação de chaves API dos agentes IA por workspace (AES-256-GCM; qualquer string — derivada com SHA-256)
APP_ENCRYPTION_KEY=troque_por_segredo_longo_para_agentes_ia

# JWT (auth /api/v1/auth/*) — mínimo 32 caracteres
JWT_SECRET=troque_por_segredo_de_32_chars_minimo_xx
JWT_ACCESS_TTL_MINUTES=1440
JWT_REFRESH_TTL_DAYS=7

# Respostas automáticas no webhook (master switch). Chave pode ser só no agente (UI); .env é fallback.
AUTO_REPLY_ENABLED=false
LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# Fallback de chave para agentes com TTS Gemini e LLM OpenAI (se não guardarem gemini_tts_api_key na UI).
# Modelo e instrução antes do texto (ritmo [PAUSA]/[HESITA]/[GAGUEJA]); vazio = preset na API.
# GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
# GEMINI_TTS_INSTRUCTION=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# === dev:stack + WhatsApp (npm run docker:dev:stack ou docker:dev + dev:stack) ===
# Docker: só Postgres + Redis + Evolution (NÃO uses --profile api — API corre no PC).
# WHATSAPP_PROVIDER=evolution
# EVOLUTION_BASE_URL=http://127.0.0.1:8081
# EVOLUTION_API_KEY=wa_saas_evolution_dev_key_change_me
# EVOLUTION_WEBHOOK_API_KEY=wa_saas_evolution_dev_key_change_me
# INSECURE_SKIP_WEBHOOK_AUTH=true
#
# Obrigatório: mesma porta que HTTP_PORT — a Evolution (Docker) chama o teu go run no host.
# PUBLIC_WEBHOOK_BASE_URL=http://host.docker.internal:8088
#
# URL que a Evolution usa para GET dos ficheiros antes do POST /send/media (por defeito = PUBLIC_WEBHOOK_BASE_URL).
# Obrigatório para auto-resposta em voz (TTS): a Evolution tem de alcançar este host (mesmo que PUBLIC_WEBHOOK_BASE_URL).
# PUBLIC_MEDIA_BASE_URL=http://host.docker.internal:8088
# MEDIA_UPLOAD_DIR=.tmp/media_uploads
# Cópia local por mensagem (miniaturas / áudio na Inbox após envio pelo site)
# MEDIA_PERSISTENT_DIR=.tmp/message_media
# MEDIA_MAX_UPLOAD_BYTES=26214400
# MEDIA_TOKEN_TTL_MINUTES=30
#
# Agente com TTS OmniVoice (local): URL por agente na UI (Agentes) ou fallback global aqui.
# OMNIVOICE_DEFAULT_BASE_URL=http://127.0.0.1:8000
# Voz OmniVoice quando o agente deixa "voz" vazia (ex.: clone com sotaque BR a partir de voice-profiles/atendimento_br).
# OMNIVOICE_DEFAULT_TTS_VOICE=clone:atendimento_br
# — API no host + OmniVoice no host: 127.0.0.1:8000
# — API em Docker + OmniVoice no host: http://host.docker.internal:8000
# Arranca o motor com: npm run omnivoice:server (ver services/omnivoice-server/README.md). Endpoint: POST /v1/audio/speech (compat. OpenAI).
#
# === TTS OpenAI (text-to-speech) ===
# Modelo por defeito na API se o agente não definir openai_tts_model (ex.: gpt-4o-mini-tts).
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Texto fixo opcional enviado como "instructions" na API OpenAI TTS (vazio = omitido).
# OPENAI_TTS_INSTRUCTIONS=
#
# === ElevenLabs (cloud) ===
# xi-api-key (opcional): usada como fallback quando o agente ElevenLabs não tem chave na UI.
# ELEVENLABS_API_KEY=
# Modelo por defeito no corpo JSON (ex.: eleven_multilingual_v2).
# ELEVENLABS_DEFAULT_MODEL=eleven_multilingual_v2
# Raiz da API (vazio = https://api.elevenlabs.io). Contas com residência de dados: ver docs ElevenLabs.
# ELEVENLABS_API_BASE_URL=https://api.elevenlabs.io
#
# Ligação telefónica outbound (ConvAI + Twilio no painel ElevenLabs) — POST /api/v1/elevenlabs/outbound-call
# https://elevenlabs.io/docs/conversational-ai/integrations/twilio
# ELEVENLABS_CONVAI_AGENT_ID=
# ID do número Twilio associado ao agente (UI ElevenLabs → Phone numbers).
# ELEVENLABS_CONVAI_AGENT_PHONE_NUMBER_ID=
#
# === Kokoro (local, API compatível OpenAI — ex. Kokoro-FastAPI) ===
# Fallback quando o agente não tem kokoro_base_url na UI.
# KOKORO_DEFAULT_BASE_URL=http://127.0.0.1:8880
# Corpo JSON "model" no POST /v1/audio/speech (depende do servidor; vazio = defeito no código).
# KOKORO_TTS_MODEL=
# Docker: npm run kokoro:server (ver services/kokoro-server/README.md). Endpoint: POST /v1/audio/speech.
#
# Timbre (só tokens em inglês permitidos pelo modelo; vírgula + espaço). Vazio = preset no código (female, young adult, portuguese accent, low pitch).
# OMNIVOICE_DESIGN_INSTRUCT=female, middle-aged, portuguese accent, moderate pitch
# Opcional: qualidade/latência (API aceita ~0.25–4 speed, 1–64 num_step). 0 ou omitido = defaults da app (~0.90 e 48).
# OMNIVOICE_TTS_SPEED=0.90
# OMNIVOICE_TTS_NUM_STEP=48
#
# API no Docker (npm run docker:dev:api): o compose força PUBLIC_WEBHOOK_BASE_URL=http://api:8080; aí o front usa localhost:8080.
