{
  "name": "chatbot",
  "private": true,
  "description": "Scripts de desenvolvimento local (API + web + opcional gateway). Requer Node e Go no PATH.",
  "scripts": {
    "docker:deps": "node scripts/docker-compose-exec.js infra/docker-compose.deps.yml up -d",
    "docker:dev": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml up -d",
    "docker:dev:stack": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml up -d",
    "docker:dev:api": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml --profile api up -d --build",
    "docker:dev:api:rebuild": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml --profile api build --no-cache api && node scripts/docker-compose-exec.js infra/docker-compose.dev.yml --profile api up -d --force-recreate api",
    "docker:down": "node scripts/docker-compose-exec.js infra/docker-compose.deps.yml down",
    "docker:dev:down": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml down",
    "dev:stack": "concurrently -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:stack:whatsapp": "node scripts/docker-compose-exec.js infra/docker-compose.dev.yml up -d && concurrently -n api,web \"npm run dev:api\" \"npm run dev:web\"",
    "dev:stack:gw": "concurrently -n api,web,gw \"npm run dev:api\" \"npm run dev:web\" \"npm run dev:gw\"",
    "dev:api": "cd backend && go run ./cmd/api",
    "dev:web": "cd apps/web && npm run dev",
    "dev:gw": "cd services/whatsapp-gateway && node src/server.js",
    "wait:inbound": "cd backend && go run ./cmd/waitinbound",
    "omnivoice:server": "powershell -ExecutionPolicy Bypass -File scripts/run-omnivoice-server.ps1",
    "kokoro:server": "powershell -ExecutionPolicy Bypass -File scripts/run-kokoro-server.ps1",
    "kokoro:server:native": "powershell -ExecutionPolicy Bypass -File scripts/run-kokoro-server-native.ps1",
    "tts:local": "concurrently -n omnivoice,kokoro \"npm run omnivoice:server\" \"npm run kokoro:server\"",
    "tts:extras:install": "powershell -ExecutionPolicy Bypass -File scripts/install-tts-extras.ps1",
    "tts:extras:samples": "powershell -ExecutionPolicy Bypass -File scripts/generate-voice-samples-extras.ps1",
    "fish:download-checkpoints": "powershell -ExecutionPolicy Bypass -File scripts/download-fish-speech-checkpoints.ps1",
    "fish:server": "powershell -ExecutionPolicy Bypass -File scripts/run-fish-speech-server.ps1",
    "fish:tts:construcao-tags": "powershell -ExecutionPolicy Bypass -File scripts/run-fish-construcao-tags.ps1",
    "cosyvoice:server": "powershell -ExecutionPolicy Bypass -File scripts/run-cosyvoice-server.ps1",
    "cosyvoice:download-model": "powershell -ExecutionPolicy Bypass -File scripts/download-cosyvoice-model.ps1",
    "voice-samples:paid": "python scripts/generate-voice-samples-paid.py --skip-openai",
    "voice-samples:paid:gemini-missing": "python scripts/generate-voice-samples-paid.py --skip-openai --gemini-only-missing",
    "voice-samples:paid:gemini-female-venda": "powershell -ExecutionPolicy Bypass -File scripts/run-gemini-female-venda.ps1"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
