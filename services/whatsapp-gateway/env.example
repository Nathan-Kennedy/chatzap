# Copiar para .env na mesma pasta (não commitar).
# Mesmos Postgres/Redis que o backend (URLs abaixo); ver ../../docs/DEV_LOCAL.md

# Base wa_saas (mesmo Postgres que a API Go)
DATABASE_URL=postgres://wa_saas:wa_saas_dev_change_me@127.0.0.1:5432/wa_saas?sslmode=disable

# Redis DB 2 — evita colisão com API (0) e Evolution (1)
REDIS_URL=redis://127.0.0.1:6379/2

WA_INSTANCE_NAME=default
# Credenciais Baileys por instância: WA_AUTH_DIR/<nome>/
WA_AUTH_DIR=./data/auth

WA_GATEWAY_HTTP_PORT=3090
WA_REDIS_CHANNEL_PREFIX=wa:gw
LOG_LEVEL=warn
