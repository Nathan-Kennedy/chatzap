# Copie para apps/web/.env — deve alinhar com backend CORS_ALLOW_ORIGINS (mesma origem)
# Guia: ../../docs/DEV_LOCAL.md | Hetzner/Coolify: ../../docs/HETZNER_CLOUD_SETUP.md
# Deploy Vercel (Root Directory apps/web, VITE_* no painel): ../../docs/DEPLOY_VERCEL.md

# API REST com prefixo /api/v1 — tem de apontar para a MESMA API onde corres "Instâncias → sincronizar webhook".
#
# --- Opção A: tudo no PC (recomendado para desenvolver API+UI) ---
# API no PC (npm run dev:stack → go run), porta típica 8088:
VITE_API_BASE_URL=http://localhost:8088/api/v1
VITE_WS_URL=ws://localhost:8088/ws
#
# API só no Docker local (contentor 8080): comenta A e usa:
# VITE_API_BASE_URL=http://localhost:8080/api/v1
# VITE_WS_URL=ws://localhost:8080/ws
#
# --- Opção B: UI no PC (Vite :5173) + API em produção (Hetzner/Coolify) ---
# No Coolify/backend, CORS_ALLOW_ORIGINS tem de incluir http://localhost:5173
# Substitui pelo domínio real da API (ex.: sslip.io ou api.teudominio.com). HTTP → ws:// ; HTTPS → wss://
# VITE_API_BASE_URL=http://SEU_DOMINIO_API/api/v1
# VITE_WS_URL=ws://SEU_DOMINIO_API/ws

# true apenas em desenvolvimento local para UI sem backend
# VITE_ENABLE_AUTH_MOCK=true

# Se o backend usar cookies (refresh httpOnly), defina true
# VITE_API_WITH_CREDENTIALS=true

# Links legais (login)
# VITE_PRIVACY_URL=https://seusite.com/privacidade
# VITE_TERMS_URL=https://seusite.com/termos

# Opcional
# VITE_SENTRY_DSN=
